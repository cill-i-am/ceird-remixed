{
  "name": "@ceird/db",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./relations": {
      "types": "./src/relations.ts",
      "import": "./src/relations.ts"
    },
    "./effect-schema": {
      "types": "./src/effect-schema.ts",
      "import": "./src/effect-schema.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js"
      },
      "./relations": {
        "types": "./dist/relations.d.ts",
        "import": "./dist/relations.js"
      },
      "./effect-schema": {
        "types": "./dist/effect-schema.d.ts",
        "import": "./dist/effect-schema.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "generate": "drizzle-kit generate --config drizzle.config.ts",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.3",
    "effect": "4.0.0-beta.85"
  },
  "devDependencies": {
    "drizzle-kit": "1.0.0-rc.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
