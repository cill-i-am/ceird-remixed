{
  "name": "@ceird/db",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./relations": {
      "types": "./src/relations.ts",
      "import": "./src/relations.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js"
      },
      "./relations": {
        "types": "./dist/relations.d.ts",
        "import": "./dist/relations.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.3"
  },
  "devDependencies": {
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
